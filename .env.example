# Server酱推送密钥 (可选，配置后启用Server酱推送)
SERVERCHAN_KEY=

# WxPusher推送配置 (可选，需同时配置TOKEN和UIDS)
WXPUSHER_TOKEN=
WXPUSHER_UIDS=

# 企业微信机器人Webhook URL (可选，配置后启用企业微信推送)
WECOM_WEBHOOK=

# 抓取间隔时间，单位：分钟 (默认60)
FETCH_INTERVAL=60

# 每个信息源最多获取条数 (默认10)
MAX_ITEMS_PER_SOURCE=10

# HackerNews最低票数过滤 (默认100)
MIN_SCORE=100

# GitHub搜索语言，逗号分隔 (默认: rust,python,typescript)
GITHUB_LANG=rust,golang,java,python,typescript
